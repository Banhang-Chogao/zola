# Sao chép thành .env và điền giá trị thật.
# Set giá trị này trên Render/Railway dashboard, KHÔNG commit .env vào git.

# ============= Required =============

# Redis connection URL — lấy từ Render Redis Internal URL hoặc Railway plugin
REDIS_URL=redis://default:password@host:6379

# Origin được phép gọi API qua CORS (chỉ blog của bạn)
CORS_ORIGIN=https://banhang-chogao.github.io

# URL public của service NÀY (cho redirect_uri OAuth callback)
BACKEND_URL=https://blog-visitor-api.onrender.com

# URL blog (để redirect về sau auth)
BLOG_URL=https://banhang-chogao.github.io/zola

# ============= GitHub OAuth (CMS auth) =============
# Tạo tại https://github.com/settings/developers → New OAuth App
# Authorization callback URL phải = ${BACKEND_URL}/auth/callback

GH_CLIENT_ID=Iv1.xxxxxxxxxxxxx
GH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email được phép vào CMS — comma-separated. Thêm contributor: append email.
# Phải là email đã verified trên GitHub mới được chấp nhận.
ADMIN_EMAILS=tamsudev.com@gmail.com

# Session sống bao lâu (seconds). Default 7200 = 2 tiếng idle timeout.
SESSION_TTL=7200

# ============= Optional =============

# (Optional) Key Redis dùng cho counter. Default 'blog:visitors'.
COUNTER_KEY=blog:visitors
