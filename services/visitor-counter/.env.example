# Sao chép thành .env và điền giá trị thật.
# Set giá trị này trên Render/Railway dashboard, KHÔNG commit .env vào git.

# ============= Required =============

# Redis connection URL — lấy từ Render Redis Internal URL hoặc Railway plugin
REDIS_URL=redis://default:password@host:6379

# Origin được phép gọi API qua CORS (chỉ blog của bạn)
CORS_ORIGIN=https://banhang-chogao.github.io

# URL public của service NÀY (cho redirect_uri OAuth callback)
BACKEND_URL=https://blog-visitor-api.onrender.com

# URL blog (để redirect về sau auth)
BLOG_URL=https://banhang-chogao.github.io/zola

# ============= GitHub OAuth (CMS auth) =============
# Tạo tại https://github.com/settings/developers → New OAuth App
# Authorization callback URL phải = ${BACKEND_URL}/auth/callback

GH_CLIENT_ID=Iv1.xxxxxxxxxxxxx
GH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email được phép vào CMS — comma-separated. Thêm contributor: append email.
# Phải là email đã verified trên GitHub mới được chấp nhận.
ADMIN_EMAILS=292648126+Banhang-Chogao@users.noreply.github.com

# ============= Auth provider rollout (GitHub → Google) =============
# AUTH_PROVIDER: github (default) | dual (cả Google + GitHub) | google (chỉ Google)
# Rollout: đặt "dual" trước → test Google → đổi "google". Rollback = "github".
AUTH_PROVIDER=dual

# ============= Google OAuth / OpenID Connect (CMS auth) =============
# Tạo "Web application" OAuth Client tại Google Cloud Console.
# Authorized redirect URI phải = GOOGLE_REDIRECT_URI bên dưới (khớp CHÍNH XÁC).
# Scope chỉ openid/email/profile — KHÔNG xin Gmail API scope.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# Mặc định suy từ BACKEND_URL ({BACKEND_URL}/auth/google/callback) nếu để trống.
GOOGLE_REDIRECT_URI=https://blog-visitor-api.onrender.com/auth/google/callback
# Email Google được phép vào CMS — comma-separated. Để trống → fallback ADMIN_EMAILS.
GOOGLE_ADMIN_EMAILS=admin@gmail.com

# Session sống bao lâu (seconds). Default 7200 = 2 tiếng idle timeout.
SESSION_TTL=7200

# ============= Optional =============

# (Optional) Key Redis dùng cho counter. Default 'blog:visitors'.
COUNTER_KEY=blog:visitors

# ============= IMDB Scraper Proxy (cho /api/movies + /dien-anh) =============
# Public service: https://imdb.iamidiotareyoutoo.com/docs/index.html
# Đổi endpoint chính xác bạn muốn dùng (search, top, popular...) qua var
# này — backend walker linh hoạt tự nhận diện schema. Không cần redeploy
# code khi đổi URL.
IMDB_API_URL=https://imdb.iamidiotareyoutoo.com/search?q=trending

# Optional: cache TTL IMDB (default 86400 = 24h).
IMDB_CACHE_TTL=86400
