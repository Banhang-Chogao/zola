public/
.DS_Store
*.swp
__pycache__/
*.pyc
.venv*/
scripts/.venv*/

# Workflow log artifacts — không bao giờ commit
perf-fix.txt
perf-scan.txt
perf-summary.txt
fix-log.txt
fixed-summary.txt
pr-body.md
reports/performance/*.json
!reports/performance/.gitkeep

# Sensitive: never commit tokens/keys
ghp_*
*.pem
*.key
.env
.env.*

# Paywall runtime data — không commit DB local / backup strip tạm
data/paywall.db
data/vipzone.db
data/.paywall-content-backup.json

# ff.py AI-Agent — logs + teach feedback (local only)
.ff/

# Generated pagination anchors (scripts/build_feed_pagination.py)
content/feed-anchor-*.md
content/posting/feed-anchor-*.md

# Extracted Zola binary (CI/local build only — source is the .tar.gz)
/zola

# Vaccine/QA runtime state, logs, volatile reports — never commit (V15)
# These files change on every QA/vaccine run and cause spurious merge conflicts.
# State/lock files
data/*-state.json
# Runtime logs
data/*.log
# Per-run volatile reports (not displayed in Zola templates)
data/vaccine-hotfix-report.json
reports/rule-conflict-report.json
reports/rule-conflict-report.md
