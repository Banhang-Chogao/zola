public/
.DS_Store
*.swp
__pycache__/
*.pyc
.venv*/
scripts/.venv*/

# Workflow log artifacts — không bao giờ commit
perf-fix.txt
perf-scan.txt
perf-summary.txt
fix-log.txt
fixed-summary.txt
pr-body.md
reports/performance/*.json
